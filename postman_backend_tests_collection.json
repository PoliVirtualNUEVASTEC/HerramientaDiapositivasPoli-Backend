      "name": "1. Crear usuario de prueba",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"fullName\": \"{{test_user_fullname}}\",\n  \"email\": \"{{test_user_email}}\",\n  \"password\": \"{{test_user_password}}\"\n}"
        },
        "url": {
          "raw": "{{base_url}}/users/",
          "host": [
            "{{base_url}}"
          ],
          "path": [
            "users"
          ]
        }
      },
      "response": [],
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Usuario creado o ya existe', function () {",
              "    pm.expect(pm.response.code).to.be.oneOf([201, 409]);",
              "});"
            ]
          }
        }
      ]
    },
    {
      "name": "2. Login y guardar cookies",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"email\": \"{{test_user_email}}\",\n  \"password\": \"{{test_user_password}}\"\n}"
        },
        "url": {
          "raw": "{{base_url}}/auth/login",
          "host": [
            "{{base_url}}"
          ],
          "path": [
            "auth",
            "login"
          ]
        }
      },
      "response": [],
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Login exitoso', function () {",
              "    pm.expect(pm.response.code).to.eql(200);",
              "});",
              "const setCookieHeaders = pm.response.headers.filter(function (header) {",
              "    return header.key.toLowerCase() === 'set-cookie';",
              "});",
              "if (setCookieHeaders.length) {",
              "    const cookiePairs = setCookieHeaders.map(function (header) { return header.value.split(';')[0]; }).join('; ');",
              "    const existing = pm.collectionVariables.get('auth_cookie') || '';",
              "    const merged = existing ? existing + '; ' + cookiePairs : cookiePairs;",
              "    pm.collectionVariables.set('auth_cookie', merged);",
              "    pm.test('Cookie guardada', function () { pm.expect(merged).to.not.be.empty; });",
              "}"
            ]
          }
        }
      ]
    },
